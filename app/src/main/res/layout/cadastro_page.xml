<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9FC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D5DA3"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Voltar"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Criar Conta"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />
    </LinearLayout>

    <!-- Form Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Welcome Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bem-vindo(a)!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#084780"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preencha os dados para acessar o sistema"
                android:textSize="14sp"
                android:textColor="#5B6B85"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="sans-serif" />

            <!-- Nome completo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOME COMPLETO"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B6B85"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif" />

            <EditText
                android:id="@+id/etNomeCompleto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: Lucas Silva"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="15sp"
                android:textColor="#1E2D3D"
                android:layout_marginBottom="12dp" />

            <!-- E-mail institucional -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="E-MAIL INSTITUCIONAL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B6B85"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="seunome@edu.unifor.br"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="15sp"
                android:textColor="#1E2D3D"
                android:layout_marginBottom="12dp" />

            <!-- CPF -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CPF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B6B85"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif" />

            <EditText
                android:id="@+id/etCPF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: 000000000-00"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="15sp"
                android:textColor="#1E2D3D"
                android:layout_marginBottom="12dp" />

            <!-- Senha -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SENHA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B6B85"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif" />

            <EditText
                android:id="@+id/etSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mínimo 8 caracteres"
                android:inputType="textPassword"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="15sp"
                android:textColor="#1E2D3D"
                android:layout_marginBottom="12dp" />

            <!-- Confirme a senha -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONFIRME A SENHA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B6B85"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif" />

            <EditText
                android:id="@+id/etConfirmeSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Repita a senha"
                android:inputType="textPassword"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="15sp"
                android:textColor="#1E2D3D"
                android:layout_marginBottom="16dp" />

            <!-- Botão Cadastrar -->
            <Button
                android:id="@+id/btnCadastrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cadastrar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:padding="14dp"
                android:backgroundTint="#1474C4"
                android:layout_marginBottom="12dp" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#DDE3EC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Já tem conta?"
                    android:textSize="12sp"
                    android:textColor="#9BAAC0"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#DDE3EC" />
            </LinearLayout>

            <!-- Botão Fazer login -->
            <Button
                android:id="@+id/btnFazerLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fazer login"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1474C4"
                android:padding="10dp"
                android:background="@android:color/transparent" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
