<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_border_blue"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/capa_container"
        android:layout_width="56dp"
        android:layout_height="72dp"
        android:background="@drawable/book_cover_blue">

        <ImageView
            android:id="@+id/capa_livro"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:tint="@color/white"
            app:srcCompat="@drawable/lent_books_icon" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/emprestimo_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="POO Simplificado"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/emprestimo_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Paulo Henrique"
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/emprestimo_devolucao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Devolução: 01/04/2026"
            android:textColor="@color/border_blue"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/emprestimo_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_ativo"
            android:text="● Ativo"
            android:textColor="@color/badge_green_text"
            android:textSize="12sp" />

    </LinearLayout>
</LinearLayout>
