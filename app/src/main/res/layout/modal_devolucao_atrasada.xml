<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/modalDevolucaoAtrasadaContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_modal_notifications"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="22dp">

    <!-- HEADER COM SETINHA E TÍTULO -->
    <LinearLayout
        android:id="@+id/headerDevolucaoAtrasadaModal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="18dp">

        <ImageView
            android:id="@+id/btnBackDevolucaoAtrasada"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back"
            android:tint="#1474C4" />

        <TextView
            android:id="@+id/tvDevolucaoAtrasadaTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:text="Design Patterns"
            android:textColor="#1E2D3D"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />

    </LinearLayout>

    <!-- MENSAGEM DO MODAL -->
    <TextView
        android:id="@+id/tvDevolucaoAtrasadaMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrega 5 dias atrasada,&#10;uma taxa de R$2,50 será&#10;cobrada na devolução"
        android:textColor="#1E2D3D"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:gravity="center"
        android:lineSpacingExtra="5dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="22dp" />

    <!-- BOTÃO CONFIRMAR -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmarDevolucaoAtrasada"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Confirmar"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_blue"
        android:backgroundTint="@null"
        android:stateListAnimator="@null" />

</LinearLayout>