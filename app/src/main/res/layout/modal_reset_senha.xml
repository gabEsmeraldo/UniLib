<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/modalResetSenhaContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_modal_notifications"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="22dp">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerResetSenhaModal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="18dp">

        <ImageView
            android:id="@+id/btnBackResetSenha"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back"
            android:tint="#1474C4" />

        <TextView
            android:id="@+id/tvResetSenhaTitle"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:text="Reset de senha"
            android:textColor="#1E2D3D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />

    </LinearLayout>

    <!-- STEP 1: E-MAIL -->
    <LinearLayout
        android:id="@+id/stepEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira o e-mail cadastrado para enviarmos o código"
            android:textColor="#1E2D3D"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="14dp" />

        <EditText
            android:id="@+id/etResetEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_modal_title_outline"
            android:hint="seu@email.com"
            android:inputType="textEmailAddress"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#1E2D3D"
            android:textColorHint="#9BAAC0"
            android:textSize="14sp"
            android:layout_marginBottom="18dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEnviarCodigo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Enviar código"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- STEP 2: CODIGO -->
    <LinearLayout
        android:id="@+id/stepCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvCodigoInstrucao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira o código enviado para o e-mail xxxxxx@xxxx.com abaixo"
            android:textColor="#1E2D3D"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="14dp" />

        <EditText
            android:id="@+id/etResetCodigo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_modal_title_outline"
            android:hint="123456"
            android:inputType="number"
            android:maxLength="6"
            android:gravity="center"
            android:letterSpacing="0.4"
            android:fontFamily="monospace"
            android:textColor="#1E2D3D"
            android:textColorHint="#C9D1DD"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="18dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVerificarCodigo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Verificar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- STEP 2 ERROR: CODIGO ERRADO -->
    <LinearLayout
        android:id="@+id/stepCodigoErro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="O codigo está errado, inicie o processo novamente"
            android:textColor="#B91C1C"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="22dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirmarCodigoErro"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Confirmar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- STEP 3: NOVA SENHA -->
    <LinearLayout
        android:id="@+id/stepNovaSenha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nova senha"
            android:textColor="#1E2D3D"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etNovaSenha"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_modal_title_outline"
            android:hint="Nova senha"
            android:inputType="textPassword"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#1E2D3D"
            android:textColorHint="#9BAAC0"
            android:textSize="14sp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etConfirmarNovaSenha"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_modal_title_outline"
            android:hint="Confirmar nova senha"
            android:inputType="textPassword"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#1E2D3D"
            android:textColorHint="#9BAAC0"
            android:textSize="14sp"
            android:layout_marginBottom="18dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSalvarNovaSenha"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Salvar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- STEP 4: SUCESSO -->
    <LinearLayout
        android:id="@+id/stepSucesso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_check"
            android:tint="#16A34A"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Senha alterada com sucesso!"
            android:textColor="#1E2D3D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="22dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFecharResetSenha"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Fechar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
