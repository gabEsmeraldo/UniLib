<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/modalEditarQuantidadeContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_modal_notifications"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="22dp">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="18dp">

        <ImageView
            android:id="@+id/btnBackEditarQuantidade"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back"
            android:tint="#1474C4" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:text="Quantidade exemplares"
            android:textColor="#1E2D3D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- STEPPER ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="22dp">

        <TextView
            android:id="@+id/tvQuantidadeAtual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="8 Disponíveis"
            android:textColor="#1E2D3D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btnDecrementarQuantidade"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_stepper_button"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="−"
                android:textColor="#1474C4"
                android:textSize="22sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnIncrementarQuantidade"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_stepper_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="+"
                android:textColor="#1474C4"
                android:textSize="22sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
        </FrameLayout>

    </LinearLayout>

    <!-- CONFIRMAR -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmarEditarQuantidade"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Confirmar"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_blue"
        android:backgroundTint="@null"
        android:stateListAnimator="@null" />

</LinearLayout>
