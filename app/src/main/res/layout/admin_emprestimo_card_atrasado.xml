<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_border_red"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Book Cover -->
    <FrameLayout
        android:id="@+id/capa_container"
        android:layout_width="56dp"
        android:layout_height="72dp"
        android:background="@drawable/book_cover_red">

        <ImageView
            android:id="@+id/capa_livro"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:tint="@color/white"
            app:srcCompat="@drawable/lent_books_icon" />

    </FrameLayout>

    <!-- Info Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Book Title -->
        <TextView
            android:id="@+id/emprestimo_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Design Patterns"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- User Info: Name + CPF -->
        <TextView
            android:id="@+id/emprestimo_user_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="João Santos · CPF: 456.789.123-00"
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

        <!-- Status Info: Days overdue + Fine -->
        <TextView
            android:id="@+id/emprestimo_status_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Atrasado 5 dias · R$ 2,50"
            android:textColor="@color/badge_red_text"
            android:textSize="14sp" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/emprestimo_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_atrasado"
            android:text="● Atrasado"
            android:textColor="@color/badge_red_text"
            android:textSize="12sp" />

    </LinearLayout>
</LinearLayout>
