<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/borda_preta"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/capa_container"
        android:layout_width="64dp"
        android:layout_height="84dp"
        android:background="@drawable/borda_preta">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:srcCompat="@drawable/lent_books_icon" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/emprestimo_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="POO Simplificado"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/emprestimo_alerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Devolucao atrasada"
            android:textColor="#D32F2F"
            android:textSize="14sp"
            tools:visibility="visible" />
    </LinearLayout>
</LinearLayout>
