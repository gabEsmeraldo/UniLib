<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/modalConfirmarDevolucaoContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_modal_notifications"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="22dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="18dp">

        <ImageView
            android:id="@+id/btnBackConfirmarDevolucao"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back"
            android:tint="#1474C4" />

        <TextView
            android:id="@+id/tvConfirmarDevolucaoTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:text="Devolução"
            android:textColor="#1E2D3D"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvConfirmarDevolucaoMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmar devolução do livro em 27/03/2026?"
        android:textColor="#1E2D3D"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="22dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancelarDevolucao"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#1474C4"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_outline"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirmarDevolucao"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Confirmar Devolução"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
