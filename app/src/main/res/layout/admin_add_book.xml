<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#0D5DA3"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_chat_input_bar"
            android:backgroundTint="#33FFFFFF"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Adicionar Livro"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOME DO LIVRO"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editBookTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_input_bar"
                android:hint="Título completo"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                android:textSize="15sp"
                android:inputType="textCapSentences"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUTOR"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editAuthor"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_input_bar"
                android:hint="Nome do autor"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                android:textSize="15sp"
                android:inputType="textPersonName"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="ISBN"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editIsbn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_input_bar"
                android:hint="978-X-XX-XXXXXX-X"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                android:textSize="15sp"
                android:inputType="phone"
                android:digits="0123456789-"
                android:maxLength="17"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAGS"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editTags"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_input_bar"
                android:hint="Ex: Computação, Algoritmos"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SINOPSE"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editSynopsis"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_chat_input_bar"
                android:hint="Breve descrição do livro"
                android:padding="16dp"
                android:gravity="top"
                android:layout_marginBottom="20dp"
                android:textSize="15sp"
                android:inputType="textMultiLine"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUANTIDADE DE EXEMPLARES"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editQuantity"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_input_bar"
                android:hint="Ex: 5"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                android:textSize="15sp"
                android:inputType="number"/>

            <FrameLayout
                android:id="@+id/layoutAddImage"
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_dashed"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:id="@+id/addImageHint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼️"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Adicionar Capa"
                        android:textColor="#0D5DA3"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivAddBookPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvChangeImageHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#88000000"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Trocar"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>

            <Button
                android:id="@+id/btnEnter"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/button_background"
                android:text="Confirmar e Adicionar"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#0D4C92" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#6B7280"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>